      "type": "boolean",
      "default": false
    },
    "written_scheme_na": {
      "type": "boolean",
      "default": false
    },
    "schematics_available": {
      "type": "boolean",
      "default": false
    },
    "schematics_available_na": {
      "type": "boolean",
      "default": false
    },
    "training_records": {
      "type": "boolean",
      "default": false
    },
    "training_records_na": {
      "type": "boolean",
      "default": false
    },
    "monitoring_records": {
      "type": "boolean",
      "default": false
    },
    "monitoring_records_na": {
      "type": "boolean",
      "default": false
    },
