{
  "name": "Job",
  "type": "object",
  "properties": {
    "customer_id": {
      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "client": {
      "type": "string"
    },
    "site_name": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "property_type": {
      "type": "string",
      "enum": [
        "Nursing Home",
        "Care Home",
        "Holiday Park",
        "Factory Unit",
        "Domestic",
        "Commercial",
        "Doctors Surgery",
        "Dental Surgery",
        "Garden Centre",
        "Other"
      ],
      "default": "Nursing Home"
    },
    "assessment_date": {
      "type": "string",
      "format": "date"
    },
    "review_due": {
      "type": "string",
      "format": "date"
    },
    "report_ref": {
      "type": "string"
    },
    "visit_dates": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "In Progress",
        "Completed",
        "Reviewed",
        "Future"
      ],
      "default": "In Progress"
    },
    "risk": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ],
      "default": "MEDIUM"
    },
    "risk_override": {
      "type": "boolean",
      "default": false
    },
    "summary": {
      "type": "string"
    },
    "assessor": {
      "type": "string"
    },
    "assessor_na": {
      "type": "boolean",
      "default": false
    },
    "reviewer": {
      "type": "string"
    },
    "reviewer_na": {
      "type": "boolean",
      "default": false
    },
    "responsible_person": {
      "type": "string"
    },
    "responsible_person_na": {
      "type": "boolean",
      "default": false
    },
    "responsible_role": {
      "type": "string"
    },
    "responsible_role_na": {
      "type": "boolean",
      "default": false
    },
    "duty_holder": {
      "type": "string"
    },
    "duty_holder_na": {
